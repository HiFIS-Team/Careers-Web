# PostgreSQL 연결 문자열
# docker compose 사용 시 host를 서비스명(db)으로: postgresql://fis:fis@db:5432/fis?schema=public
DATABASE_URL="postgresql://fis:fis@localhost:5432/fis?schema=public"

# 지원서 첨부파일 저장 경로 (docker 볼륨으로 마운트 권장)
UPLOAD_DIR="./uploads"

# Auth.js (관리자 로그인)
# AUTH_SECRET: openssl rand -base64 32 로 생성
AUTH_SECRET=""
# 구글 OAuth 클라이언트 (Google Cloud Console > 사용자 인증 정보)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# 관리자 허용 구글 계정 이메일 (쉼표 구분)
ADMIN_EMAILS="admin1@gmail.com,admin2@gmail.com"

# ───────── 운영(docker compose) 전용 ─────────
# 서버의 .env에 두면 docker-compose가 DATABASE_URL을 조립합니다.
FIS_DB_USER="fis"
FIS_DB_PASSWORD="강한_비밀번호로_변경"
FIS_DB_NAME="fis_db"
# 운영 공개 URL (Auth.js 콜백용)
AUTH_URL="https://fitnessstar.co.kr"

# ───────── 알림톡 (Solapi) ─────────
# 채널 연동 + 템플릿 검수 완료 후 채우면 자동 발송됩니다. 비우면 발송 스킵.
SOLAPI_API_KEY=""
SOLAPI_API_SECRET=""
SOLAPI_SENDER=""                 # 발신번호 (예: 0212345678)
SOLAPI_PFID=""                   # 카카오 발신프로필 pfId (KA01PF...)
SOLAPI_TEMPLATE_NEW=""           # 직원용: 새 지원 접수
SOLAPI_TEMPLATE_RECEIVED=""      # 지원자용: 지원 완료
SOLAPI_TEMPLATE_PASS=""          # 지원자용: 합격
SOLAPI_TEMPLATE_FAIL=""          # 지원자용: 불합격
ALERT_PHONES=""                  # 직원 수신번호(쉼표): 대표,나
